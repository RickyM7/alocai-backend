# Modo de depuração do Django (True para desenvolvimento, False para produção)
DEBUG=True

# Chave secreta do Django usada para criptografia de sessões, tokens, etc.
# Em produção, gere uma chave segura e mantenha em sigilo.
# Para gerar uma chave: python manage.py shell -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=sua-chave-secreta-aqui

# ID do cliente OAuth do Google, necessário para o login com conta Google.
# Obtido no Google Cloud Console: https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=seu-client-id.apps.googleusercontent.com

# Lista de hosts permitidos pelo Django (separados por vírgula).
# Em produção, adicione o domínio do seu servidor.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Origens CORS extras permitidas (separadas por vírgula).
# Necessário se o frontend estiver em um domínio diferente do backend.
CORS_EXTRA_ORIGINS=

# URL de conexão com o banco de dados.
# Padrão: SQLite local. Para PostgreSQL, use algo como:
# DATABASE_URL=postgres://usuario:senha@host:5432/nome_do_banco
# DATABASE_URL=

# Credenciais de e-mail para envio de notificações via SMTP.
# Configurado para Gmail por padrão (smtp.gmail.com:587).
# Para o Gmail, é necessário gerar uma "Senha de App" em: https://myaccount.google.com/apppasswords
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Credenciais do administrador inicial, usadas pelo comando: python manage.py create_admin
# Esse comando cria o primeiro usuário admin com login por e-mail e senha.
ADMIN_EMAIL=admin@exemplo.com
ADMIN_PASSWORD=senha-segura-aqui

# Credenciais do administrador normal (opcional)
# REGULAR_ADMIN_EMAIL=admin2@exemplo.com
# REGULAR_ADMIN_PASSWORD=senha-segura-aqui